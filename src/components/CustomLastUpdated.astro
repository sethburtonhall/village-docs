---
import { Badge } from "@astrojs/starlight/components";
import { ChevronRight } from "lucide-react";

import { cn } from "@/lib/utils";
import { AnimatedGradientText } from "@/components/ui/animated-gradient-text";

const { lang = "en", lastUpdated } = Astro.locals.starlightRoute;
---

{
  lastUpdated && (
    <div class="group relative mx-auto flex items-center justify-center rounded-full px-4 py-1.5 shadow-[inset_0_-8px_10px_#8fdfff1f] transition-shadow duration-500 ease-out hover:shadow-[inset_0_-5px_10px_#8fdfff3f]">
      <span
        class={cn(
          "animate-gradient bg-linear-gradient-to-r absolute inset-0 block h-full w-full rounded-[inherit] from-[#ffaa40]/50 via-[#9c40ff]/50 to-[#ffaa40]/50 bg-size-[300%_100%] p-px",
        )}
        style={{
          WebkitMask:
            "linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0)",
          WebkitMaskComposite: "destination-out",
          mask: "linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0)",
          maskComposite: "subtract",
          WebkitClipPath: "padding-box",
        }}
      />
      🎉 <hr class="mx-2 h-4 w-px shrink-0 bg-neutral-500" />
      <AnimatedGradientText>
        <span>
          Updated:{" "}
          {lastUpdated.toLocaleDateString(lang, {
            dateStyle: "medium",
            timeZone: "UTC",
          })}
        </span>
      </AnimatedGradientText>
    </div>
  )
}
